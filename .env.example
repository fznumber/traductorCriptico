# ============================================
# CONFIGURACIÓN DE PROVIDERS
# ============================================

# THINKING PROVIDER: Solo 'ollama' o 'nvidia' (NO anthropic)
# El thinking se genera con modelos más rápidos y económicos
THINKING_PROVIDER=ollama

# AGENTES: Siempre usan Anthropic (Claude) - No configurable
# Los agentes de Fase 1, 2 y 3 requieren Claude para análisis profundo

# ============================================
# OLLAMA CONFIG
# ============================================
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=qwen3.5:4b

# ============================================
# ANTHROPIC CONFIG (Claude) - Para Agentes
# ============================================
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ============================================
# NVIDIA API CONFIG - Para Thinking
# ============================================
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=deepseek-ai/deepseek-v3.2
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ============================================
# ELEVENLABS API CONFIG - Para Audio
# ============================================
ELEVENLABS_API_KEY=tu_nueva_api_key_aqui

# Voice ID para Text-to-Speech (opcional)
# Por defecto usa 'EXAVITQu4vr4xnSDxMaL' (Sarah - voz femenina en español)
# Puedes encontrar más voces en: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
